{
  "expo": {
    "name": "Kukatonon",
    "slug": "kukatonon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "kukatonon",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0f0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.kukatonon.mobile",
      "associatedDomains": [
        "applinks:kukatonon.app",
        "applinks:www.kukatonon.app",
        "applinks:kukatonon.app",
        "applinks:www.kukatonon.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0f0a"
      },
      "package": "app.kukatonon.mobile",
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kukatonon.app",
              "pathPrefix": "/stories/"
            },
            {
              "scheme": "https",
              "host": "www.kukatonon.app",
              "pathPrefix": "/stories/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1c2a7f8f-188b-48f7-9607-a6703c9861e5"
      }
    }
  }
}
