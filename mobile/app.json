{
  "expo": {
    "name": "Kukatonon",
    "slug": "kukatonon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "kukatonon",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0f0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.kukatonon.mobile",
      "associatedDomains": [
        "applinks:kukatonon.app",
        "applinks:www.kukatonon.app",
        "applinks:kukatonon.app",
        "applinks:www.kukatonon.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Kukatonon uses your location to center the map on where you are and show you the stories closest to you.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0f0a"
      },
      "package": "app.kukatonon.mobile",
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCDN01bXbP37afoPinGD721xC7CcJZerAA"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kukatonon.app",
              "pathPrefix": "/stories/"
            },
            {
              "scheme": "https",
              "host": "www.kukatonon.app",
              "pathPrefix": "/stories/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Kukatonon uses your location to show you the stories closest to you on the map."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1c2a7f8f-188b-48f7-9607-a6703c9861e5"
      }
    }
  }
}
